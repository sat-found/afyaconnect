<?xml version="1.0"?>

<tryton>
    <data>
        <record model="ir.ui.view" id="diaspora_specialist_view_form">
            <field name="model">gnuhealth.afya.diaspora_specialist</field>
            <field name="type">form</field>
            <field name="name">diaspora_specialist_form</field>
        </record>

        <record model="ir.ui.view" id="diaspora_specialist_view_list">
            <field name="model">gnuhealth.afya.diaspora_specialist</field>
            <field name="type">tree</field>
            <field name="name">diaspora_specialist_list</field>
        </record>

        <record model="ir.action.act_window" id="act_diaspora_specialist">
            <field name="name">Diaspora Specialists</field>
            <field name="res_model">gnuhealth.afya.diaspora_specialist</field>
        </record>
        <record model="ir.action.act_window.view" id="act_diaspora_specialist_view1">
            <field name="sequence" eval="10"/>
            <field name="view" ref="diaspora_specialist_view_list"/>
            <field name="act_window" ref="act_diaspora_specialist"/>
        </record>
        <record model="ir.action.act_window.view" id="act_diaspora_specialist_view2">
            <field name="sequence" eval="20"/>
            <field name="view" ref="diaspora_specialist_view_form"/>
            <field name="act_window" ref="act_diaspora_specialist"/>
        </record>

        <menuitem parent="z_health_afya_core.menu_afya_root"
            action="act_diaspora_specialist" sequence="50" id="menu_diaspora"/>
    </data>
</tryton>
